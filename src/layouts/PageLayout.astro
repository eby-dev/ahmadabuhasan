---
import BaseLayout from './BaseLayout.astro';
import SkipLink from '@/components/layout/SkipLink.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';

type OgType = 'website' | 'article' | 'profile';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  emitPersonSchema?: boolean;
  ogType?: OgType;
}

const { title, description, image, noindex, emitPersonSchema, ogType } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  noindex={noindex}
  emitPersonSchema={emitPersonSchema}
  ogType={ogType}
>
  <SkipLink />
  <Navbar />
  <main id="main">
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  #main {
    padding-block: var(--space-12);
  }

  @media (max-width: 640px) {
    #main {
      padding-block: var(--space-8);
    }
  }
</style>
