---
import { SITE } from '@/config/site';
import { PERSON_ID, absoluteUrl } from '@/utils/seo';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': PERSON_ID,
  name: SITE.name,
  url: SITE.url,
  image: absoluteUrl(SITE.jsonLdPortraitImage),
  jobTitle: SITE.role,
  description: SITE.tagline,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.location.locality,
    addressRegion: SITE.location.region,
    addressCountry: SITE.location.country,
  },
  worksFor: {
    '@type': 'Organization',
    name: SITE.jsonLd.worksFor.name,
    address: {
      '@type': 'PostalAddress',
      addressLocality: SITE.jsonLd.worksFor.locality,
      addressRegion: SITE.jsonLd.worksFor.region,
      addressCountry: SITE.jsonLd.worksFor.country,
    },
  },
  alumniOf: {
    '@type': 'EducationalOrganization',
    name: SITE.jsonLd.alumniOf.name,
    address: {
      '@type': 'PostalAddress',
      addressLocality: SITE.jsonLd.alumniOf.locality,
      addressRegion: SITE.jsonLd.alumniOf.region,
      addressCountry: SITE.jsonLd.alumniOf.country,
    },
  },
  hasOccupation: {
    '@type': 'Occupation',
    name: SITE.role,
    occupationLocation: {
      '@type': 'City',
      name: SITE.location.locality,
    },
  },
  knowsAbout: SITE.jsonLd.knowsAbout,
  sameAs: SITE.jsonLd.sameAs,
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
