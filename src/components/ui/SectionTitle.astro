---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  level?: 1 | 2 | 3;
  align?: 'left' | 'center';
  id?: string;
}

const { eyebrow, title, description, level = 2, align = 'left', id } = Astro.props;

const Tag = `h${level}` as 'h1' | 'h2' | 'h3';
---

<header class:list={['section-title', `align-${align}`]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <Tag id={id} class="title">{title}</Tag>
  {description && <p class="description">{description}</p>}
</header>

<style>
  .section-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .align-center {
    align-items: center;
    text-align: center;
  }

  .eyebrow {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--color-accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0;
  }

  .title {
    margin: 0;
  }

  .description {
    font-size: var(--fs-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0;
  }

  .align-center .description {
    margin-inline: auto;
  }
</style>
