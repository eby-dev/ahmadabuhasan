---
interface Props {
  href: string;
  class?: string;
  ariaLabel?: string;
  showIndicator?: boolean;
}

const { href, class: className, ariaLabel, showIndicator = false } = Astro.props;
---

<a href={href} target="_blank" rel="noopener noreferrer" class={className} aria-label={ariaLabel}>
  <slot />
  {
    showIndicator && (
      <svg
        aria-hidden="true"
        width="14"
        height="14"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M6 2h8v8" />
        <path d="M14 2 4 12" />
      </svg>
    )
  }
</a>
