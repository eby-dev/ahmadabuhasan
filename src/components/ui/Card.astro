---
interface Props {
  as?: 'article' | 'div' | 'li' | 'section';
  interactive?: boolean;
  padding?: 'sm' | 'md' | 'lg' | 'none';
  class?: string;
}

const {
  as: Tag = 'article',
  interactive = false,
  padding = 'md',
  class: className = '',
} = Astro.props;

const classes = ['card', `padding-${padding}`, interactive && 'interactive', className]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes}>
  <slot />
</Tag>

<style>
  .card {
    display: block;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .padding-none {
    padding: 0;
  }
  .padding-sm {
    padding: var(--space-4);
  }
  .padding-md {
    padding: var(--space-6);
  }
  .padding-lg {
    padding: var(--space-8);
  }

  .interactive {
    transition:
      border-color var(--motion-fast),
      box-shadow var(--motion-fast),
      transform var(--motion-fast);
  }

  .interactive:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
</style>
